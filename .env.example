# ─────────────────────────────────────────────────────────────
# REQUIRED — all environments
# ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=generate-with-python-secrets-module

# Optional: a dedicated signing key for JWT auth tokens. Defaults to
# DJANGO_SECRET_KEY when unset. Set it (same generator) to rotate the JWT key
# independently of SECRET_KEY (which also signs sessions, CSRF, and other tokens).
# JWT_SIGNING_KEY=generate-with-python-secrets-module

# ─────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# `python manage.py runserver` uses config.settings.development by default:
#   - SQLite database (no setup needed, db.sqlite3 is created automatically)
#   - Console email backend (magic-link emails are printed to the terminal)
# The values below already work out of the box for local development.
# ─────────────────────────────────────────────────────────────
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAGIC_LINK_BASE_URL=http://localhost:3000/magic-link
SHARE_LINK_BASE_URL=http://localhost:3000/share

# ─────────────────────────────────────────────────────────────
# IMAGE UPLOADS — Cloudinary (all environments, including local)
# Images upload straight from the browser to Cloudinary; Django only signs
# the request. Without this the app runs fine, but image uploads will fail.
# Create a free account at https://cloudinary.com, then copy the value of
# "API environment variable" from your dashboard (Settings -> API Keys).
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# ─────────────────────────────────────────────────────────────
# CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# ─────────────────────────────────────────────────────────────
# PRODUCTION (self-hosted: Heroku, DigitalOcean, AWS, ...)
# Switch settings to production and replace the local values above with
# your real domain. See HEROKU.md for a full deployment walk-through.
# ─────────────────────────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=YOUR-DOMAIN.com
# DATABASE_URL=postgres://user:password@host:5432/dbname
# CORS_ALLOWED_ORIGINS=https://YOUR-DOMAIN.com
# CSRF_TRUSTED_ORIGINS=https://YOUR-DOMAIN.com
# MAGIC_LINK_BASE_URL=https://YOUR-DOMAIN.com/verify
# RSVP_BASE_URL=https://YOUR-DOMAIN.com/rsvp
# SHARE_LINK_BASE_URL=https://YOUR-DOMAIN.com/share

# Email — magic-link auth REQUIRES SMTP in production (any provider works,
# e.g. Mailgun, SendGrid). In local development email goes to the console.
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=postmaster@YOUR-DOMAIN.com
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=noreply@YOUR-DOMAIN.com
# Optional: SMTP socket timeout in seconds (default 10). Caps how long a slow or
# hung mail provider can stall a web request before the platform router times out.
# EMAIL_TIMEOUT=10
