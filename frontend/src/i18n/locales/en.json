  "welcome": {
    "greeting": "Hello, {{name}}",
    "pageTitle": "Welcome to OIUEEI!",
    "description": "OIUEEI is an open-source platform for sharing within trusted communities. Create collections for gifts, sales, loans, orders, events, swaps, wishes and appointments — then invite friends to browse, reserve and interact. Everything stays between people who know each other.",
    "createCollection": "Create collection",
    "editProfile": "Edit profile",
    "whoUsesTitle": "Who uses OIUEEI?",
    "personaLalaTitle": "Lala — The Multitasker.",
    "personaLalaBody": "Off on sabbatical and clearing out the flat with zero fuss — a tenner each, you come collect, everything gone by the 25th. But Lala also runs a community van-sharing scheme, because not everything needs selling when it can simply be borrowed.",
    "personaLeleTitle": "Lele — The Nurturer.",
    "personaLeleBody": "Up at five baking architectural cakes with ingredients you can actually pronounce, and — when not in the kitchen — giving away succulent cuttings from a beautifully curated photo album. Order a cake or adopt a plant: both come with care instructions.",
    "personaLiliTitle": "Lili — The Swapper.",
    "personaLiliBody": "She lends drills, steamers and ladders for free because nobody needs a drill every day. She also runs an electronics swap board for Arduino devotees — no cash, just components and mutual respect. Return things clean. That is the deal.",
    "personaLoloTitle": "Lolo — The Enthusiast.",
    "personaLoloBody": "Hosts a book club for those who like their heroes tortured and their moors windswept — and also teaches the hammered dulcimer, that dreamy trapezoidal harp. One appointment for a cosy read, another for the loveliest sound in the world.",
    "personaLuluTitle": "Lulu — The Connector.",
    "personaLuluBody": "Nobody quite knows where she finds these things or where she goes. Her community shelf fills weekly with objects that have lived a life, ready for a new home. Members get a weekly email digest — because what arrives on the shelf on Monday deserves to be gone by Friday.",
    "personaLalaLink1": "Vanlife on tap",
    "personaLeleLink1": "Lele's Cakes",
    "personaLeleLink2": "Lele's Leafy Lounge",
    "personaLiliLink1": "Lili's Borrow Borrow",
    "personaLiliLink2": "Lili's Circuit Swap",
    "personaLoloLink1": "Lolo's book club",
    "personaLoloLink2": "Lolo's dulcimer sessions",
    "personaLuluLink1": "Lulu's Phantom Shelf",
    "personaLalaLink2": "Lala's sabbatical sale"
  },
