  "welcome": {
    "greeting": "Kaixo, {{name}}",
    "pageTitle": "Ongi etorri OIUEEIra!",
    "description": "OIUEEI kode irekiko plataforma bat da konfiantzazko komunitateetan partekatzeko. Sortu bildumak opariak, salmentak, maileguak, eskaerak, ekitaldiak, trukeak, nahiak eta hitzorduetarako — eta gonbidatu lagunak arakatzera, erreserbatzera eta elkarreraginean aritzera. Dena ezagutzen diren pertsonen artean gelditzen da.",
    "createCollection": "Bilduma sortu",
    "editProfile": "Profila editatu",
    "whoUsesTitle": "Nork erabiltzen du OIUEEI?",
    "personaLalaTitle": "Lala — Multitaskerra.",
    "personaLalaBody": "Oporretara joatekoa da eta dena saltzen du zailtasunik gabe — hamar euro gauza bakoitzeko, zuk jasotzen duzu, dena 25erako amaituta. Baina Lalak ere furgonetaren partekatze komunitarioko eskema bat kudeatzen du, ez dago-eta dena saldu beharrik mailegatu besterik ez badezakegu.",
    "personaLeleTitle": "Lele — Zaintzailea.",
    "personaLeleBody": "Goizeko bostetan esnatuta pastela arkitektonikoak egiten ditu ahoskatzen diren osagaiekin, eta — sukaldetik kanpo dagoenean — sukulento-txertatxoak oparituz album eder batetik. Eskatu pastela edo adoptatu landarea: biak zaintzeko argibideekin etorriko dira.",
    "personaLiliTitle": "Lili — Trukatzailea.",
    "personaLiliBody": "Zulagailuak, lurrun-garbigailuak eta eskailerak doan mailegutzen ditu, inork ez baitu zulagailua egunero behar. Arduino zaleen elektronika-truke txartela ere kudeatzen du — dirurik gabe, osagaiak eta elkarrekiko errespetua baino ez. Itzuli gauzak garbi. Hori da akordioa.",
    "personaLoloTitle": "Lolo — Zaletua.",
    "personaLoloBody": "Liburu-kluba antolatzen du heroi atormentatuak eta haize-bideetako lurraldeak gustatzen zaizkienen tzat — eta dulzimer-klaseak ere ematen ditu, harparen forma trapezoidal hori. Hitzordu bat irakurketa lasai baterako, beste bat munduko soinu politenaren truke.",
    "personaLuluTitle": "Lulu — Konektatzailea.",
    "personaLuluBody": "Inork ez daki ondo non aurkitzen dituen gauza hauek ezta nora joaten den ere. Bere komunitate-apalategia astero betetzen da bizitza bat izandako objektuekin, etxe berri baten zain. Kideek astero e-posta laburpena jasotzen dute — astelehenetatik apategira iristen dena ostiraleko baino lehen joan behar da-eta.",
    "personaLalaLink1": "Furgonetaren partekatze eskema",
    "personaLeleLink1": "Leleren pastelak",
    "personaLeleLink2": "Leleren landare-albuma",
    "personaLiliLink1": "Liliren mailegutze-apalategia",
    "personaLiliLink2": "Liliren elektronika-trukea",
    "personaLoloLink1": "Loloren liburu-kluba",
    "personaLoloLink2": "Loloren dulzimer-saioak",
    "personaLuluLink1": "Luluren apalategi fantasma",
    "personaLalaLink2": "Lalaren sabatiko-salmenta"
  },
